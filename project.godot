; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Legend's Hero"
run/main_scene="uid://be7k5ypbb0km0"
config/features=PackedStringArray("4.7", "Forward Plus")
config/icon="res://icon.svg"

[audio]

buses/default_bus_layout="uid://d0ylppukq2jxb"

[autoload]

SoundEffectsPlayer="*uid://donw4pepoqbq1"
ItemEventBus="*uid://btr1orqjqifeb"
InputEventBus="*res://scripts/autoload/input_event_bus.gd"
Inventory="*res://scripts/autoload/inventory.gd"

[display]

window/size/viewport_width=320
window/size/viewport_height=180
window/size/borderless=true
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="canvas_items"

[dotnet]

project/assembly_name="New Game Project"

[file_customization]

folder_colors={
"res://assets/": "red",
"res://resources/": "green",
"res://scenes/": "blue",
"res://scripts/": "orange"
}

